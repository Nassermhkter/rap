rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == 'nassermokhter50@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidArtist(data) {
      return data.keys().hasAll(['name', 'image']) &&
             data.keys().size() >= 2 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.image is string && data.image.size() <= 500;
    }

    function isValidTrack(data) {
      return data.keys().hasAll(['title', 'artistName', 'audioUrl']) &&
             data.keys().size() >= 3 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.artistName is string && data.artistName.size() > 0 && data.artistName.size() <= 100 &&
             data.audioUrl is string && data.audioUrl.size() <= 500;
    }

    function isValidNews(data) {
      return data.keys().hasAll(['title', 'content', 'image']) &&
             data.keys().size() >= 3 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 10000 &&
             data.image is string && data.image.size() <= 500;
    }

    // --- Collections ---

    match /artists/{artistId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(artistId) && isValidArtist(incoming());
      allow update: if isAdmin() && isValidArtist(incoming());
      allow delete: if isAdmin();
    }

    match /tracks/{trackId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(trackId) && isValidTrack(incoming());
      allow update: if isAdmin() && isValidTrack(incoming());
      allow delete: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(newsId) && isValidNews(incoming());
      allow update: if isAdmin() && isValidNews(incoming());
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
